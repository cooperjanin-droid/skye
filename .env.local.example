# Supabase Configuration
# -------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL
#   Where to find it: Supabase Dashboard → Your Project → Settings → API
#   It looks like: https://xyzxyzxyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# NEXT_PUBLIC_SUPABASE_ANON_KEY
#   Where to find it: Supabase Dashboard → Your Project → Settings → API → Project API Keys → anon / public
#   It is a long JWT string starting with "eyJ..."
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site URL (use http://localhost:3000 during development, your Vercel URL in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
